<!-- REFERENCE INDEX -->
<section>
  <h2>Reference Index</h2>
  {% for domain in ref_domains %}
  <div class="ref-block">
    <div class="ref-domain">{{ domain_prefix[domain] }} &nbsp;{{ domain }}</div>
    {% if domain_top_title[domain] %}<div class="ref-top-title">Most used: {{ domain_top_title[domain] }}</div>{% endif %}
    {% for entry in domain_url_list[domain] %}
    <div class="ref-entry">
      <span class="reftitle">{{ entry.ref }}</span> &nbsp;
      <span class="reftitle">{{ entry.title if entry.title else "(no title)" }}</span>
      <span class="ref-url">{{ entry.url }}</span>
    </div>
    {% endfor %}
  </div>
  {% endfor %}
