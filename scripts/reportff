<section>
  <h2>Session Archaeology</h2>
  <p class="muted" style="font-size:8pt; margin-bottom:0.4cm;">
    Top {{ sessions|length }} sessions by duration. Indentation = click depth. ↩ = backtrack.
  </p>
  {% for sess in sessions %}
  <div class="session">
    <div class="session-header">
      {{ sess.date }} · {{ sess.start }} – {{ sess.end }} · {{ sess.duration }}
      <span class="session-tag" style="background:{{ colors[sess.category] }}22; color:{{ colors[sess.category] }};">{{ sess.category }}</span>
