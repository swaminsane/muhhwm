.ref-entry { font:8.5pt "Courier New",monospace; color:var(--ink); margin:0.08cm 0; }
.ref-entry .reftitle { font-weight:600; }
.ref-url { color:var(--muted); font-size:7.5pt; display:block; padding-left:0.4cm; }

.muted { color:var(--muted); }
.mono { font-family:"Courier New",monospace; }
.page-break { page-break-after:always; }
</style>
</head>
<body>

