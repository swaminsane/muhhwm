</html>
"""

# ═══════════════════════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════════════════════

def main():
    parser = argparse.ArgumentParser(description="Monthly Firefox history report generator")
    parser.add_argument("year_month", help="Target month as YYYY/MM or YYYY-MM")
    args = parser.parse_args()

    sep = "/" if "/" in args.year_month else "-"
    parts = args.year_month.split(sep)
    if len(parts) != 2:
        raise SystemExit("ERROR: year_month must be in format YYYY/MM or YYYY-MM")
    try:
        YEAR = int(parts[0])
        MONTH = int(parts[1])
    except ValueError:
        raise SystemExit("ERROR: year and month must be integers")

    INPUT_DIR = BASE_HISTORY_DIR / str(YEAR) / f"{MONTH:02d}"
    OUTPUT_DIR = BASE_EXPORT_DIR / str(YEAR) / f"{MONTH:02d}"
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)

    base_name = f"{YEAR}-{MONTH:02d}-report"
    if DARK_MODE:
        base_name += "-d"
    OUTPUT_HTML = OUTPUT_DIR / f"{base_name}.html"
    OUTPUT_PDF = OUTPUT_DIR / f"{base_name}.pdf"

    print(f"Loading history from {INPUT_DIR} …")
    entries = load_entries(INPUT_DIR)
    raw_queries = load_search_queries(INPUT_DIR)
    print(f"  → {len(entries)} visits, {len(raw_queries)} search queries")

    print("Processing …")
    compute_dwell(entries)
    sessions = build_sessions(entries)

    ref_map, domain_prefix, domain_url_list, domain_top_title = build_references(entries)

    data = compile_all(
        entries, sessions, ref_map, domain_prefix, domain_url_list, domain_top_title
    )

    query_cards = build_query_cards(raw_queries, domain_prefix)
    video_cards = build_video_cards(entries, domain_prefix)

    cat_order = sorted(
        data["categories"].keys(),
        key=lambda c: data["categories"][c]["visits"],
        reverse=True
    )
    colors = dict(CATEGORY_COLORS)
    for c in cat_order:
        if c not in colors:
            colors[c] = colors.get("other", "#6b6b6b")

    ctx = {
        "year": YEAR,
        "month": MONTH,
        "generated_at": datetime.utcnow().strftime("%Y-%m-%d %H:%M UTC"),
        "total_visits": data["total_visits"],
        "unique_urls": data["unique_urls"],
        "unique_domains": data["unique_domains"],
        "total_time": data["total_time"],
        "first_date": data["first_date"],
        "last_date": data["last_date"],
        "daily": data["daily"],
        "max_day_visits": data["max_day_visits"],
        "days_in_month": data["days_in_month"],
        "heatmap": data["heatmap"],
        "categories": data["categories"],
        "cat_order": cat_order,
        "domain_rows": data["domain_rows"],
        "sessions": data["sessions"],
        "transitions": data["transitions"],
        "query_cards": query_cards,
        "video_cards": video_cards,
        "colors": colors,
        "inline_refs": INLINE_REFERENCES,
        "domain_prefix": domain_prefix,
        "domain_url_list": domain_url_list,
        "domain_top_title": domain_top_title,
        "ref_domains": list(domain_url_list.keys()),
        "dark_mode": DARK_MODE,
        "fmt_dur": fmt_dur,
        "fmt_clock": fmt_clock,
    }

    print("Rendering HTML …")
    template = Template(HTML_TEMPLATE)
    html_body = template.render(ctx)

    with open(OUTPUT_HTML, "w", encoding="utf-8") as f:
        f.write(html_body)
    print(f"  → {OUTPUT_HTML}")

    if GENERATE_PDF:
        if not WEASYPRINT_OK:
            print("PDF generation skipped (WeasyPrint not installed).")
        else:
            print("Rendering PDF …")
            HTML(string=html_body).write_pdf(OUTPUT_PDF)
            print(f"  → {OUTPUT_PDF}")
            if AUTO_OPEN_PDF:
                import subprocess
                subprocess.run(["xdg-open", str(OUTPUT_PDF)], check=False)

    print("Done.")

if __name__ == "__main__":
    main()
