  <table class="data trans">
    <tr><th>From</th><th>→</th><th>To</th><th>Count</th><th>Avg Dwell After</th>{% if inline_refs %}<th>Refs</th>{% endif %}</tr>
    {% for t in transitions %}
    <tr>
      <td>{{ t.from }}</td><td>→</td><td>{{ t.to }}</td>
      <td>{{ t.count }}</td><td>{{ t.avg_after }}</td>
      {% if inline_refs %}<td class="mono">{{ t.from_ref }} → {{ t.to_ref }}</td>{% endif %}
    </tr>
