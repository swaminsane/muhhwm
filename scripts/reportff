    Period {{ first_date }} → {{ last_date }}<br>
    Generated {{ generated_at }}<br>
    Firefox History Analytics
  </div>
</div>

<!-- EXECUTIVE SUMMARY -->
<section>
  <h2>Executive Summary</h2>
  {% for cat in cat_order %}
    {% set s = categories[cat] %}
    {% set pct = (s.visits / total_visits * 100)|round(0)|int if total_visits else 0 %}
    <div class="bar-row">
      <div class="bar-label" style="text-transform:capitalize;">{{ cat }}</div>
      <div class="bar-track"><div class="bar-fill" style="width:{{ pct }}%; background:{{ colors[cat] }};"></div></div>
      <div class="bar-pct">{{ pct }}%</div>
      <div class="bar-detail">{{ s.visits }} visits, {{ fmt_dur(s.seconds) }}</div>
    </div>
  {% endfor %}
</section>

<!-- DAILY PULSE -->
<section>
  <h2>Daily Pulse</h2>
  {% for d in range(1, days_in_month+1) %}
    {% set n = daily.get(d, 0) %}
    {% set w = (n / max_day_visits * 100)|round(0)|int if max_day_visits else 0 %}
    <div class="pulse-row">
      <div class="pulse-day">{{ "%02d"|format(month) }}-{{ "%02d"|format(d) }}</div>
      <div class="pulse-track"><div class="pulse-fill" style="width:{{ w }}%;"></div></div>
      <div class="pulse-n">{{ n }}<br>visit{{ "s" if n != 1 else "" }}</div>
    </div>
  {% endfor %}
</section>

<div class="page-break"></div>

<!-- HOURLY HEATMAP -->
<section>
  <h2>Hourly Heatmap</h2>
  <p class="muted" style="margin-bottom:0.3cm; font-size:8pt;">
    Each row is a day of the month. Darker cells = more visits in that hour.
  </p>
  <table class="heatmap">
    <tr><th style="width:1.2cm;"></th>{% for h in range(24) %}<th>{{ "%02d"|format(h) }}</th>{% endfor %}</tr>
    {% for d in range(1, days_in_month+1) %}
    <tr>
      <th>{{ "%02d"|format(d) }}</th>
      {% for h in range(24) %}
        {% set n = heatmap[d][h] %}
        {% set cls = "h0" %}
        {% if n > 0 %}{% set cls = "h1" %}{% endif %}
        {% if n >= 25 %}{% set cls = "h2" %}{% endif %}
        {% if n >= 50 %}{% set cls = "h3" %}{% endif %}
        {% if n >= 75 %}{% set cls = "h4" %}{% endif %}
        {% if n >= 100 %}{% set cls = "h5" %}{% endif %}
        <td class="{{ cls }}">{{ n if n > 0 else "·" }}</td>
      {% endfor %}
    </tr>
    {% endfor %}
  </table>
</section>

<!-- SEARCH QUERY LOG -->
<section>
  <h2>Search Query Log</h2>
  {% for engine, cards in query_cards.items() %}
  <h3>{{ engine|capitalize }} ({{ cards|length }} queries)</h3>
  <div class="card-grid">
    {% for card in cards %}
    <div class="card">
      <div class="ctext">
        {% if card.count > 1 %}<span class="ccount">×{{ card.count }}</span>{% endif %}
        {% if card.query|length > 25 %}{{ card.query[:22] ~ '…' }}{% else %}{{ card.query }}{% endif %}
      </div>
      <div class="cdate">{{ card.searched_on }} {% if card.ref %}<span class="cref">[{{ card.ref }}]</span>{% endif %}</div>
    </div>
    {% endfor %}
  </div>
  {% endfor %}
</section>

<!-- VIDEOS WATCHED -->
{% if video_cards %}
<section>
  <h2>Videos Watched</h2>
  <div class="card-grid">
    {% for v in video_cards %}
    <div class="card">
      <div class="ctext">
        {% if v.count > 1 %}<span class="ccount">×{{ v.count }}</span>{% endif %}
        {% if v.title|length > 25 %}{{ v.title[:22] ~ '…' }}{% else %}{{ v.title }}{% endif %}
      </div>
      <div class="cdate">{{ v.date }} {% if v.ref %}<span class="cref">[{{ v.ref }}]</span>{% endif %}</div>
    </div>
    {% endfor %}
  </div>
</section>
