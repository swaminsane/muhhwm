#!/usr/bin/env python3
"""
ffreport  —  Monthly Firefox History PDF/HTML Report Generator
Usage:  ffreport YYYY/MM   (e.g.  ffreport 2025/08)

Reads daily JSON history dumps from
    ~/.local/share/firefox/history/YYYY/MM/
and writes a designed report to
    ~/.local/share/firefox/history-export/YYYY/MM/YYYY-MM-report.html
                                          …/YYYY-MM-report.pdf   (if WeasyPrint available)

All configuration flags are at the top of this file.
"""

import argparse
import calendar
import json
import sys
from collections import Counter, defaultdict
from datetime import datetime, timedelta
from pathlib import Path

# ── Optional dependencies ────────────────────────────────────────────────────
try:
    from jinja2 import Template
except ImportError as exc:
    raise SystemExit(
        "ERROR: jinja2 is required. Install it with:\n"
        "    pip install jinja2"
    ) from exc

try:
    from weasyprint import HTML
    WEASYPRINT_OK = True
except ImportError:
    WEASYPRINT_OK = False

# ═══════════════════════════════════════════════════════════════════════════════
# CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

BASE_HISTORY_DIR = Path.home() / ".local/share/firefox/history"
BASE_EXPORT_DIR  = Path.home() / ".local/share/firefox/history-export"

SESSION_GAP_MINUTES          = 30         # idle minutes before a new session (time‑based)
DOMAIN_DEEP_DIVE_MIN_VISITS  = 69         # minimum visits to appear in Domain Deep‑Dive
TRANSITION_MIN_COUNT         = 10         # minimum transition count to show
MAX_SESSIONS                 = 50         # top N sessions by duration
INLINE_REFERENCES            = True       # show [R-x.y] tags inside tables

DARK_MODE                    = False      # dark colour scheme + adds '-d' to output filename

MEDIA_DOMAINS = [
    "youtube.com",
    "m.youtube.com",
    "youtu.be",
    "invidious.snopyta.org",
    "odysee.com",
]

GENERIC_VIDEO_TITLES = {
    "", "youtube", "youtube - history", "youtube - subscriptions",
    "youtube - feed", "invidious", "odysee", "yewtube",
}

CATEGORY_RULES = [
    ("entertainment", ["youtube.com", "youtu.be", "miruro.tv", "pahe.win",
                       "kwik.cx", "thetvapp.to", "tvpass.org", "instagram.com"]),
    ("research",      ["google.com", "bing.com", "duckduckgo.com", "archive.org",
                       "ukiyo-e.org", "data.ukiyo-e.org", "jaodb.com",
                       "nationalarchives.gov.uk", "lyx.org", "mfa.org",
                       "syngof.fr", "ukiyoe-gallery.com",
                       "stackoverflow.com", "unix.stackexchange.com",
                       "reddit.com"]),
    ("work",          ["github.com", "gitlab.com", "localhost", "chatgpt.com",
                       "openai.com", "chat.deepseek.com"]),
    ("admin",         ["bceceboard.bihar.gov.in", "admissions.nic.in",
                       "gov.in", "gov.uk"]),
]

CATEGORY_COLORS = {
    "entertainment": "#c25e00",
    "research":      "#2e5aac",
    "work":          "#3a7d44",
    "admin":         "#8b6914",
    "other":         "#6b6b6b",
}

DOMAIN_ALIASES = {}   # e.g. {"m.youtube.com": "youtube.com"}

GENERATE_PDF   = True
AUTO_OPEN_PDF  = False

# ═══════════════════════════════════════════════════════════════════════════════

def parse_ts(ts: str) -> datetime:
    return datetime.fromisoformat(ts.replace("Z", "+00:00"))

def fmt_dur(seconds: float) -> str:
    if seconds < 60:
        return f"{int(seconds)}s"
    mins = int(seconds // 60)
    secs = int(seconds % 60)
    if mins < 60:
        return f"{mins}m {secs}s"
    hrs = mins // 60
    mins %= 60
    return f"{hrs}h {mins}m {secs}s"

def fmt_clock(dt: datetime) -> str:
    return dt.strftime("%H:%M")

def normalize_domain(domain: str) -> str:
    if not domain:
        return "local-files"
    domain = domain.lower().replace("www.", "")
    return DOMAIN_ALIASES.get(domain, domain)

def categorize(domain: str) -> str:
    for cat, frags in CATEGORY_RULES:
        if any(frag in domain for frag in frags):
            return cat
    return "other"

# ── Data loading ──
def load_entries(input_dir: Path):
    entries = []
    if not input_dir.exists():
        raise SystemExit(f"ERROR: Input directory not found: {input_dir}")
    json_files = sorted(input_dir.glob("*.json"))
    if not json_files:
        raise SystemExit(f"ERROR: No .json files in {input_dir}")
    for jfile in json_files:
        with open(jfile, "r", encoding="utf-8") as fh:
            data = json.load(fh)
        for rec in data.get("entries", []):
            base = {
                "url": rec.get("url", ""),
                "title": rec.get("title", "") or "",
                "domain": normalize_domain(rec.get("domain", "")),
                "visit_count": rec.get("visit_count", 1),
                "typed_count": rec.get("typed_count", 0),
                "frecency": rec.get("frecency", 0),
            }
            for v in rec.get("visits", []):
                entry = {
                    **base,
                    "visit_id": v["visit_id"],
                    "from_visit": v.get("from_visit", 0),
                    "timestamp_raw": v["timestamp"],
                    "timestamp": parse_ts(v["timestamp"]),
                    "visit_type": v.get("visit_type", "unknown"),
                }
                entries.append(entry)
    entries.sort(key=lambda x: x["timestamp"])
    return entries

def load_search_queries(input_dir: Path):
    queries = []
    for jfile in sorted(input_dir.glob("*.json")):
        with open(jfile, "r", encoding="utf-8") as fh:
            data = json.load(fh)
        for q in data.get("search_queries", []):
            if "last_searched" not in q:
                continue
            queries.append(q)
    return queries

# ── Dwell & sessions ──
def compute_dwell(entries: list):
    gap_sec = SESSION_GAP_MINUTES * 60
    for i in range(len(entries)):
        if i + 1 < len(entries):
            diff = (entries[i+1]["timestamp"] - entries[i]["timestamp"]).total_seconds()
            entries[i]["dwell"] = diff if diff < gap_sec else 0
        else:
            entries[i]["dwell"] = 0

def build_sessions(entries: list):
    sessions = []
    cur = []
    for e in entries:
        if not cur:
            cur.append(e)
            continue
        gap = (e["timestamp"] - cur[-1]["timestamp"]).total_seconds()
        if gap > SESSION_GAP_MINUTES * 60:
            sessions.append(cur)
            cur = [e]
        else:
            cur.append(e)
    if cur:
        sessions.append(cur)
    return sessions

# ── Reference system ──
def build_references(entries: list):
    domain_urls = defaultdict(list)
    domain_first = {}
    url_seen = set()
    for e in entries:
        d = e["domain"]
        u = e["url"]
        t = e.get("title", "")
        ts = e["timestamp"]
        if d not in domain_first or ts < domain_first[d]:
            domain_first[d] = ts
        if u not in url_seen:
            url_seen.add(u)
            domain_urls[d].append((u, t))
    sorted_domains = sorted(domain_first.keys(), key=lambda d: domain_first[d])

    ref_map = {}
    domain_prefix = {}
    domain_url_list = {}
    domain_top_title = {}

    for idx, d in enumerate(sorted_domains, 1):
        prefix = f"R-{idx}"
        domain_prefix[d] = prefix
        urls = domain_urls[d]
        titles = Counter()
        for u, t in urls:
            titles[t] += 1
        domain_top_title[d] = titles.most_common(1)[0][0] if titles else ""

        entries_out = []
        for j, (u, t) in enumerate(urls, 1):
            ref = f"{prefix}.{j}"
            ref_map[u] = ref
            entries_out.append({"url": u, "title": t or "", "ref": ref})
        domain_url_list[d] = entries_out

    return ref_map, domain_prefix, domain_url_list, domain_top_title

# ── Main compilation ──
def compile_all(entries, sessions, ref_map, domain_prefix, domain_url_list, domain_top_title):
    total_visits = len(entries)
    unique_urls = len({e["url"] for e in entries})
    unique_domains = len({e["domain"] for e in entries})
    total_seconds = sum(e.get("dwell", 0) for e in entries)
    first_ts = entries[0]["timestamp"]
    last_ts = entries[-1]["timestamp"]
    days_in_month = calendar.monthrange(last_ts.year, last_ts.month)[1]

    # daily pulse
    daily = Counter()
    for e in entries:
        daily[e["timestamp"].day] += 1
    max_day_visits = max(daily.values()) if daily else 1

    # hourly heatmap
    heatmap = {d: {h: 0 for h in range(24)} for d in range(1, days_in_month+1)}
    for e in entries:
        heatmap[e["timestamp"].day][e["timestamp"].hour] += 1

    # categories
    cat_stats = defaultdict(lambda: {"visits": 0, "seconds": 0})
    for e in entries:
        c = categorize(e["domain"])
        cat_stats[c]["visits"] += 1
        cat_stats[c]["seconds"] += e.get("dwell", 0)

    # domain deep-dive (filtered)
    dom_stats = defaultdict(lambda: {
        "visits": 0, "dwell_total": 0, "dwell_n": 0,
        "first": None, "last": None, "titles": Counter(), "urls": set()
    })
    for e in entries:
        d = e["domain"]
        s = dom_stats[d]
        s["visits"] += 1
        if e.get("dwell", 0) > 0:
            s["dwell_total"] += e["dwell"]
            s["dwell_n"] += 1
        if s["first"] is None or e["timestamp"] < s["first"]:
            s["first"] = e["timestamp"]
        if s["last"] is None or e["timestamp"] > s["last"]:
            s["last"] = e["timestamp"]
        if e["title"]:
            s["titles"][e["title"]] += 1
        s["urls"].add(e["url"])

    domain_rows = []
    for d in sorted(dom_stats.keys(), key=lambda x: dom_stats[x]["visits"], reverse=True):
        s = dom_stats[d]
        if s["visits"] < DOMAIN_DEEP_DIVE_MIN_VISITS:
            continue
        avg_dwell = (s["dwell_total"] / s["dwell_n"]) if s["dwell_n"] else 0
        top_title = s["titles"].most_common(1)[0][0] if s["titles"] else ""
        refs = [ref_map[u] for u in s["urls"] if u in ref_map]
        refs.sort()
        domain_rows.append({
            "domain": d,
            "visits": s["visits"],
            "time": fmt_dur(s["dwell_total"]),
            "avg_dwell": fmt_dur(avg_dwell),
            "window": f"{fmt_clock(s['first'])} – {fmt_clock(s['last'])}",
            "top_title": top_title[:45] + ("…" if len(top_title) > 45 else ""),
            "category": categorize(d),
            "refs": refs,
            "prefix": domain_prefix.get(d, ""),
        })

    # transitions (filtered)
    trans = defaultdict(lambda: {"count": 0, "dwell_after": []})
    for sess in sessions:
        for i in range(len(sess)-1):
            a = sess[i]["domain"]
            b = sess[i+1]["domain"]
            if a == b:
                continue
            trans[(a,b)]["count"] += 1
            trans[(a,b)]["dwell_after"].append(sess[i+1].get("dwell", 0))

    trans_rows = []
    for (a,b), data in sorted(trans.items(), key=lambda x: x[1]["count"], reverse=True):
        if data["count"] < TRANSITION_MIN_COUNT:
            continue
        avg_after = sum(data["dwell_after"])/len(data["dwell_after"]) if data["dwell_after"] else 0
        trans_rows.append({
            "from": a, "to": b, "count": data["count"],
            "avg_after": fmt_dur(avg_after),
            "from_ref": domain_prefix.get(a, ""),
            "to_ref": domain_prefix.get(b, ""),
        })

    # sessions (tree rendering)
    session_objs = []
    for sess in sessions:
        if not sess:
            continue
        start = sess[0]["timestamp"]
        end = sess[-1]["timestamp"]
        dur_sec = (end - start).total_seconds()
        cats = Counter(categorize(e["domain"]) for e in sess)
        main_cat = cats.most_common(1)[0][0] if cats else "other"

        sess_ids = {e["visit_id"]: e for e in sess}
        child_map = defaultdict(list)
        roots = []
        for e in sess:
            pid = e.get("from_visit", 0)
            if pid in sess_ids:
                child_map[pid].append(e)
            else:
                roots.append(e)
        roots.sort(key=lambda x: x["timestamp"])
        for k in child_map:
            child_map[k].sort(key=lambda x: x["timestamp"])

        def render_tree(node, depth=0, is_last=False, ancestors=None):
            if ancestors is None:
                ancestors = set()
            lines = []
            prefix = "  " * depth
            connector = "└─" if is_last and depth > 0 else ("├─" if depth > 0 else "")
            time_str = fmt_clock(node["timestamp"])
            dwell_str = fmt_dur(node.get("dwell", 0)) if node.get("dwell", 0) > 0 else "0s"
            title = node.get("title", "")[:38] + ("…" if len(node.get("title", "")) > 38 else "")
            ref = ref_map.get(node["url"], "")
            backtrack = node["domain"] in ancestors
            mark = " ↩" if backtrack else ""
            line = f"{prefix}{connector} [{dwell_str}] {time_str}  {node['domain']}{mark}  {title}"
            if ref and INLINE_REFERENCES:
                line += f"  [{ref}]"
            lines.append(line)
            children = child_map.get(node["visit_id"], [])
            for i, child in enumerate(children):
                lines.extend(render_tree(child, depth+1, i==len(children)-1, ancestors | {node["domain"]}))
            return lines

        chain_text = []
        for i, root in enumerate(roots):
            chain_text.extend(render_tree(root, 0, i==len(roots)-1))

        session_objs.append({
            "start": fmt_clock(start),
            "end": fmt_clock(end),
            "date": start.strftime("%b %d"),
            "duration": fmt_dur(dur_sec),
            "category": main_cat,
            "chain_text": chain_text,
        })

    session_objs.sort(key=lambda x: x["duration"], reverse=True)
    session_objs = session_objs[:MAX_SESSIONS]

    return {
        "total_visits": total_visits,
        "unique_urls": unique_urls,
        "unique_domains": unique_domains,
        "total_time": fmt_dur(total_seconds),
        "first_date": first_ts.strftime("%Y-%m-%d"),
        "last_date": last_ts.strftime("%Y-%m-%d"),
        "daily": daily,
        "max_day_visits": max_day_visits,
        "days_in_month": days_in_month,
        "heatmap": heatmap,
        "categories": cat_stats,
        "domain_rows": domain_rows,
        "sessions": session_objs,
        "transitions": trans_rows,
    }

# ── Search query cards ──
def build_query_cards(raw_queries, domain_prefix):
    by_engine = defaultdict(list)
    for q in raw_queries:
        eng = q.get("engine", "unknown")
        text = q.get("query", "")
        if not text:
            continue
        ts = parse_ts(q.get("last_searched", "1970-01-01T00:00:00+00:00"))
        by_engine[eng].append({
            "query": text,
            "searched_on": ts.strftime("%Y-%m-%d"),
            "count": q.get("count", 1),
            "domain": q.get("domain", ""),
        })

    for eng in by_engine:
        merged = {}
        for card in by_engine[eng]:
            txt = card["query"]
            if txt in merged:
                merged[txt]["count"] += card["count"]
                if card["searched_on"] < merged[txt]["searched_on"]:
                    merged[txt]["searched_on"] = card["searched_on"]
            else:
                merged[txt] = card
        by_engine[eng] = sorted(merged.values(), key=lambda c: c["count"], reverse=True)

    engine_order = sorted(by_engine.keys(), key=lambda e: len(by_engine[e]), reverse=True)
    result = {}
    for eng in engine_order:
        cards = by_engine[eng]
        for c in cards:
            c["ref"] = domain_prefix.get(c["domain"], "")
        result[eng] = cards
    return result

# ── Videos watched ──
def build_video_cards(entries, domain_prefix):
    generic_lower = {t.lower() for t in GENERIC_VIDEO_TITLES}
    by_title = defaultdict(list)
    for e in entries:
        if e["domain"] not in MEDIA_DOMAINS:
            continue
        title = e.get("title", "").strip()
        if title.lower() in generic_lower:
            continue
        by_title[title].append(e)

    cards = []
    for title, visits in by_title.items():
        count = len(visits)
        first_ts = min(v["timestamp"] for v in visits)
        domain = visits[0]["domain"]
        ref = domain_prefix.get(domain, "")
        cards.append({
            "title": title,
            "count": count,
            "date": first_ts.strftime("%b %d %H:%M"),
            "ref": ref,
        })
    cards.sort(key=lambda c: c["date"], reverse=True)
    return cards

